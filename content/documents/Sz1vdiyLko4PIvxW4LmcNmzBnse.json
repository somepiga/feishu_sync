/p></td><td><p>&nbsp;</p></td><td rowspan=\"9\"><p>decoder</p></td><td><p>1</p></td><td><p>32</p></td><td><p>512</p></td><td><p>27594.11</p></td><td><p>62685.67</p></td><td><p>44.02%</p></td><td><p>59627</p></td></tr><tr><td><p>46.28%</p></td><td><p>-2.26%</p></td><td><p>&nbsp;</p></td><td><p>1</p></td><td><p>32</p></td><td><p>576</p></td><td><p>32768.00</p></td><td><p>70355.67</p></td><td><p>46.57%</p></td></tr><tr><td><p>65890</p></td><td><p>49.73%</p></td><td><p>-3.16%</p></td><td><p>&nbsp;</p></td><td><p>1</p></td><td><p>32</p></td><td><p>640</p></td><td><p>34492.63</p></td><td><p>70705</p></td></tr><tr><td><p>48.78%</p></td><td><p>68762.67</p></td><td><p>50.16%</p></td><td><p>-1.38%</p></td><td><p>&nbsp;</p></td><td><p>8</p></td><td><p>32</p></td><td><p>512</p></td><td><p>220752.84</p></td></tr><tr><td><p>305019.3</p></td><td><p>72.37%</p></td><td><p>319976.3</p></td><td><p>68.99%</p></td><td><p>3.38%</p></td><td><p>&nbsp;</p></td><td><p>8</p></td><td><p>32</p></td><td><p>576</p></td></tr><tr><td><p>262144.00</p></td><td><p>362599</p></td><td><p>72.30%</p></td><td><p>362570</p></td><td><p>72.30%</p></td><td><p>-0.01%</p></td><td><p>&nbsp;</p></td><td><p>8</p></td><td><p>32</p></td></tr><tr><td><p>640</p></td><td><p>275941.05</p></td><td><p>374667.3</p></td><td><p>73.65%</p></td><td><p>372342.3</p></td><td><p>74.11%</p></td><td><p>-0.46%</p></td><td><p>&nbsp;</p></td><td><p>16</p></td></tr><tr><td><p>32</p></td><td><p>512</p></td><td><p>441505.68</p></td><td><p>603872.7</p></td><td><p>73.11%</p></td><td><p>620071.7</p></td><td><p>71.20%</p></td><td><p>1.91%</p></td><td><p>&nbsp;</p></td></tr><tr><td><p>16</p></td><td><p>32</p></td><td><p>576</p></td><td><p>524288.00</p></td><td><p>675046</p></td><td><p>77.67%</p></td><td><p>688207</p></td><td><p>76.18%</p></td><td><p>1.49%</p></td></tr></table></div><p>4.尝试增大QK 与softmax之间的同步粒度以及TLR数量, 尝试big_little方案</p><p>5. 尝试Q*K结果存放GMB</p><p> 性能提升2%</p><figure class=\"doc-image\"><img src=\"content/media/AzTVbEVHhoSJ7vxz2R2cVgmmnyc.bin\" alt=\"image\" loading=\"lazy\" width=\"1584\" height=\"294\"></figure><p>6.dump波形</p><figure class=\"doc-image\"><img src=\"content/media/Iw7xbiCUFoptC9xzNSicogyxnYe.png\" alt=\"image\" loading=\"lazy\" width=\"1045\" height=\"61\"></figure><p>Q*K结果存放GMB波形：</p><figure class=\"doc-image\"><img src=\"content/media/O2orbURTVoOGPUxV55zc8I41nHg.png\" alt=\"image\" loading=\"lazy\" width=\"1154\" height=\"91\"></figure><p>&nbsp;</p><p>&nbsp;</p>",
