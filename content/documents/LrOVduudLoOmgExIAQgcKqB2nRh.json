, 512)\n\nreload_a_from_hbm_to_gib\n\n64 * 2048 * 2 / 60 = 4,369\n\n64*7168*2 / 60 =15,291\n\n64*4096*2/60=8,738\n\n64*11008*2/60 =23,483\n\n1\n\n1\n\n1\n\n1\n\nreload_b_from_hbm_to_gmb\n\n2048*547*1/40=28,006\n\n7168*547*1/40 = 98,022\n\n4096*274/30 = 37,410\n\n11008*274/30\n=100,539\n\n2\n\n2 * (8192 / 512) = 32\n\n2(H折到batch上的数目为2）\n\n2 * (8192 / 512 ) = 32\n\nreload_b_from_gmb_to_gib\n\n\n\n\n\n\n\n\n\noutH / inH = 512 / 256 = 2\n\noutH / inH = 512 / 256 = 2\n\n\n\n\n\nload_a_from_hbm_to_gib\n\n\n\n\n\n\n\n\n\nhPerSpc * kPerSpc * TypeA * reload_a_hbm_to gib / DTG_UMA_BW = 16384 * 4096  * 2 * 1 / 60 = 1,118,481 * 2 = 2,236,962\n\n16384 * 7168 * 2 * 1 / 60 = 3,914,683\n\n16384 * 4096 * 2 * 1 / 60 = 2,236,962\n\n16384 * 11008 * 2 * 1 / 60 = 6,011,835\n\nload_b_from_hbm_to_gmb\n\n\n\n\n\n\n\n\n\nkPerSpc * wPerSpc * TypeB * reload_b_hbm_to_gmb / NUMA_BW = 4096 * 547 * 1 * 2 / 40 = 112,025\n\n7168 * 547 * 1 * （16384 / 512) / 40 = 3,136,716\n\n4096 * 274 * 2 * 1 / 40 = 56,115\n\n11008 * 274 * 2 * 1 / 40 = 281,804 * 16 = 2,412,953\n\nload_b_from_gmb_to_gib\n\n\n\n\n\n\n\n\n\nkPerSpc * wPerSpc * TypeB * reload_b_gmb_to_gib / GMB_BW = 2048 * 547 * 1 * 2 / 256 = 8,752\n\n\n\n\n\n\n\ngemm\n\n\n\n\n\n\n\n\n\nhPerSpc * kPerSpc * wPerSpc / 16384 = 16384 * 2048 * 768 / 16384 = 1,572,864 * = 3,145,728\n\n\n16384 * 7168 * 768 / 16384 = 5,505,024\n\n16384 * 4096 * 512 / 16384 = 2,097,152\n\n16384 * 11008 * 512 / 16384 = 5,636,096\n\nwrite_l2\n\n\n\n\n\n\n\n\n\nhPerSpc * wPerSpc * FP32 * (kPerSpc / inK) / L2_BW = 16384 * 768 * 4 * (2048 / 512) / (256 ) = 786,432\n\n\n\n\n\n\n\ntypecast_write\n\n\n\n\n\n\n\n\n\nhPerSpc * wPerSpc * BF16 / 30 = 16384 * 547 * 2 / 30 =597,469\n\n16384 * 547 * 2 / 30 = 597,469\n\n16384 * 274 * 2 / 30 = 299,281\n\n16384 * 274 * 2 / 30 = 299,281\n\nresult\n\n\n\n\n\n\n\n\n\n 3,145,728 + 112,025 + 597,469 = 3,855,222 + 3,145,728 = 7,000,950\n\n 5,505,024 + 3,136,716 +  597,469 = 9,239,209\n\n2,236,962 + 56,115 + 299,281 = 2,592,358\n\n6,011,835 + 2,412,953 + 299,281 = 8,724,069\n\n\n\n\n\n\n\n\n\n\n\n\n\n不折K：\noutH = 512, outK = 7168, outW = 576 can pass 8.5ms\n\noutH = 1024, outK=7168, outW = 576\ninPartitionW = 128: 8.11 ms\n（不折K）\n\n\n\nimage2024-6-27_19-0-2.png\n\nimage2024-6-27_19-0-25.png\n\n两者的差距主要在Gemm Cycle上，EU cycle相同\n故这个case性能差主要是来自于inPartitionW = 256，所以实际会算512，造成gemm cycle的多算\n\noutH = 1024, outK = 8192, outW = 288, inPartitionW = 256: 9.2 ms\n\noutH = 1024, outK = 8192, outW = 288, inPartitionW = 128: 7.9 ms\n\n",
