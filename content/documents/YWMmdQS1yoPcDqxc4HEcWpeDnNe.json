76\n\n\n\n32x512\n\n\n\n6.8382\n\n9.4443\n\n9.4737\n\n10.4728\n\n10.8284\n\n\n\n64x512\n\n\n\n13.7351\n\n18.8758\n\n18.9617\n\n21.0456\n\n21.6436\n\nLlama2-7B\nnuma_vs_uma4_7b \n\n 展开源码 \nTEST(MmaFunc, test_numa_vs_uma4_7b) {\n    float mesc = 0.0;\n    // constexpr int32_t SPC_NUM = 12;\n    EXPECT_TRUE(\n        (test_MatMul_FoldW_uma4<S8, SPC_NUM, SPC_NUM, SPC_NUM, CASE4_TYPECAST_S8>(1 * 1, 4096, 4096, mesc, 10)));\n    EXPECT_TRUE(\n        (test_MatMul_FoldW_uma4<S8, SPC_NUM, SPC_NUM, SPC_NUM, CASE4_TYPECAST_S8>(32 * 1, 4096, 4096, mesc, 10)));\n    EXPECT_TRUE(\n        (test_MatMul_FoldW_uma4<S8, SPC_NUM, SPC_NUM, SPC_NUM, CASE4_TYPECAST_S8>(64 * 1, 4096, 4096, mesc, 10)));\n    EXPECT_TRUE(\n        (test_MatMul_FoldW_uma4<S8, SPC_NUM, SPC_NUM, SPC_NUM, CASE4_TYPECAST_S8>(128 * 1, 4096, 4096, mesc, 10)));\n\n    EXPECT_TRUE(\n        (test_MatMul_FoldW_uma4<S8, SPC_NUM, SPC_NUM, SPC_NUM, CASE4_TYPECAST_S8>(1 * 1, 4096, 12288, mesc, 10)));\n    EXPECT_TRUE(\n        (test_MatMul_FoldW_uma4<S8, SPC_NUM, SPC_NUM, SPC_NUM, CASE4_TYPECAST_S8>(32 * 1, 4096, 12288, mesc, 10)));\n    EXPECT_TRUE(\n        (test_MatMul_FoldW_uma4<S8, SPC_NUM, SPC_NUM, SPC_NUM, CASE4_TYPECAST_S8>(64 * 1, 4096, 12288, mesc, 10)));\n    EXPECT_TRUE(\n        (test_MatMul_FoldW_uma4<S8, SPC_NUM, SPC_NUM, SPC_NUM, CASE4_TYPECAST_S8>(128 * 1, 4096, 12288, mesc, 10)));\n\n    EXPECT_TRUE(\n        (test_MatMul_FoldW_uma4<S8, SPC_NUM, SPC_NUM, SPC_NUM, CASE4_TYPECAST_S8>(1 * 1, 4096, 22016, mesc, 10)));\n    EXPECT_TRUE(\n        (test_MatMul_FoldW_uma4<S8, SPC_NUM, SPC_NUM, SPC_NUM, CASE4_TYPECAST_S8>(32 * 1, 4096, 22016, mesc, 10)));\n    EXPECT_TRUE(\n        (test_MatMul_FoldW_uma4<S8, SPC_NUM, SPC_NUM, SPC_NUM, CASE4_TYPECAST_S8>(64 * 1, 4096, 22016, mesc, 10)));\n    EXPECT_TRUE(\n        (test_MatMul_FoldW_uma4<S8, SPC_NUM, SPC_NUM, SPC_NUM, CASE4_TYPECAST_S8>(128 * 1, 4096, 22016, mesc, 10)));\n\n    EXPECT_TRUE(\n        (test_MatMul_FoldW_uma4<S8, SPC_NUM, SPC_NUM, SPC_NUM, CASE4_T